# PostgreSQL
DB_USER=ecom
DB_PASSWORD=<set_your_password_here>
DB_NAME=ecom_order_hub
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_PASSWORD=<set_your_password_here>
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=<set_your_jwt_secret_here>

# Go Server
GO_SERVER_PORT=8080
PYTHON_WORKER_URL=http://localhost:8000

# Python Worker
PYTHON_WORKER_PORT=8000
GO_SERVER_URL=http://localhost:8080
CELERY_BROKER_URL=redis://:<set_your_password_here>@localhost:6379/0

# 淘宝开放平台
TAOBAO_APP_KEY=
TAOBAO_APP_SECRET=
TAOBAO_CALLBACK_URL=http://localhost:8080/api/v1/shops/auth/callback?platform=taobao

# 京东开放平台
JD_APP_KEY=
JD_APP_SECRET=
JD_CALLBACK_URL=http://localhost:8080/api/v1/shops/auth/callback?platform=jd

# 拼多多开放平台
PDD_CLIENT_ID=
PDD_CLIENT_SECRET=
PDD_CALLBACK_URL=http://localhost:8080/api/v1/shops/auth/callback?platform=pdd

# 通知 (可选)
DINGTALK_WEBHOOK=
WECOM_WEBHOOK=

# AI Agent 编排服务
AGENT_PORT=9000
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
SERVICE_ACCOUNT_USER=<set_service_account_user_here>
SERVICE_ACCOUNT_PASSWORD=<set_service_account_password_here>
